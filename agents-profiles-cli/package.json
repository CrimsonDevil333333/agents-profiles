{
  "name": "agents-profiles-cli",
  "version": "0.2.0",
  "description": "Interactive CLI to configure AI agent profiles for your project — supports OpenCode, Claude Code, GitHub Copilot, Cursor, Aider, Continue.dev, and more.",
  "type": "module",
  "bin": {
    "agents-profiles-cli": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/bin/cli.ts",
    "start": "node dist/bin/cli.js",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "opencode",
    "claude",
    "copilot",
    "cursor",
    "aider",
    "continue",
    "setup",
    "configuration"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.8.0",
    "commander": "^12.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CrimsonDevil333333/agents-profiles.git"
  },
  "homepage": "https://github.com/CrimsonDevil333333/agents-profiles"
}
